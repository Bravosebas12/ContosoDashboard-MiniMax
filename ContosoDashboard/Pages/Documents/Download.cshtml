@* Endpoint de descarga — authorize-then-stream. Ver FR-018. *@
@page "/documents/download/{Id:int}"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Mvc
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents
@inject IDocumentService DocumentService
@inject AuthenticationStateProvider AuthState
@attribute [Authorize(Policy = "Employee")]

@functions {
    [Parameter] public int Id { get; set; }

    public async Task<IActionResult> OnGetAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var nameId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(nameId, out var userId)) return new UnauthorizedResult();

        try
        {
            var (stream, fileName, contentType) = await DocumentService.OpenForDownloadAsync(Id, userId);
            return new FileStreamResult(stream, contentType) { FileDownloadName = fileName };
        }
        catch (ContosoDashboard.Services.Documents.DocumentNotFoundException) { return new NotFoundResult(); }
        catch (ContosoDashboard.Services.Documents.DocumentUnauthorizedAccessException) { return new ForbidResult(); }
    }
}
