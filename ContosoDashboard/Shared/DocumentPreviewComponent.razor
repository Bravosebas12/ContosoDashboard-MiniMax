@* Componente reutilizable para previsualizar documentos inline (PDF, imágenes). Ver FR-019. *@
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents

@if (Document == null)
{
    <p><em>No document.</em></p>
}
else if (!DocumentConstants.IsPreviewable(Document.FileType))
{
    <div class="alert alert-info mb-0">
        Preview not available for this file type (@Document.FileType).
        Use the "Download" button to open it in another application.
    </div>
}
else if (Document.FileSize > DocumentConstants.MaxPreviewSizeBytes)
{
    <div class="alert alert-warning mb-0">
        Preview not available for files larger than @DocumentConstants.MaxPreviewSizeBytes / 1024 / 1024 MB.
        Use the "Download" button.
    </div>
}
else
{
    <div class="ratio ratio-16x9 border">
        <iframe src="/DocumentFiles/Preview?id=@Document.DocumentId"
                sandbox="allow-same-origin"
                title="Preview of @Document.Title"
                style="border:0"></iframe>
    </div>
}

@code {
    [Parameter, EditorRequired] public DocumentDto? Document { get; set; }
}
