@* Componente reutilizable para previsualizar documentos inline (PDF, imágenes). Ver FR-019. *@
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents

@if (Document == null)
{
    <p><em>Sin documento.</em></p>
}
else if (!DocumentConstants.IsPreviewable(Document.FileType))
{
    <div class="alert alert-info mb-0">
        Vista previa no disponible para este tipo de archivo (@Document.FileType).
        Use el botón "Descargar" para verlo en otra aplicación.
    </div>
}
else if (Document.FileSize > DocumentConstants.MaxPreviewSizeBytes)
{
    <div class="alert alert-warning mb-0">
        Vista previa no disponible para archivos mayores a @DocumentConstants.MaxPreviewSizeBytes / 1024 / 1024 MB.
        Use el botón "Descargar".
    </div>
}
else
{
    <div class="ratio ratio-16x9 border">
        <iframe src="/documents/preview/@Document.DocumentId"
                sandbox="allow-same-origin"
                title="Vista previa de @Document.Title"
                style="border:0"></iframe>
    </div>
}

@code {
    [Parameter, EditorRequired] public DocumentDto? Document { get; set; }
}
