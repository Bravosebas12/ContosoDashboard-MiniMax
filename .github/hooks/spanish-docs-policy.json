{
  "$schema": "https://schemas.openobserve.io/vscode-hooks.json",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy", "Bypass",
          "-File",
          "${workspaceFolder}/.github/hooks/scripts/inject-language-policy.ps1"
        ],
        "timeout": 10
      }
    ]
  }
}
